# ======================================================================
# Variáveis de ambiente — SEO Brain
# ======================================================================
# Copie este arquivo para .env.local na raiz e preencha as keys que usar.
# .env.local é git-ignored.

# ----------------------------------------------------------------------
# Imagens — banco de fotos (skill /setup-images, script image-search.mjs)
# ----------------------------------------------------------------------

# Pexels API — https://www.pexels.com/api/
# Free, 200 req/h. Recomendado como provider default.
PEXELS_API_KEY=

# Unsplash API — https://unsplash.com/developers
# Free, 50 req/h. Útil como segundo provider em modo --provider=both.
UNSPLASH_ACCESS_KEY=

# OpenAI Image API — https://platform.openai.com/api-keys
# Pago (~$0.04/imagem 1024×1024). Skill /setup-images modo OpenAI.
OPENAI_API_KEY=

# ----------------------------------------------------------------------
# Email transacional (skill /setup-email)
# ----------------------------------------------------------------------

# Resend — https://resend.com/api-keys
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# ----------------------------------------------------------------------
# Site público
# ----------------------------------------------------------------------

# Domínio canônico (definitivo, pós-deploy). Se vazio, /sitemap e
# canonicals usam URL temporária Vercel.
NEXT_PUBLIC_BASE_URL=

# ----------------------------------------------------------------------
# Performance / SEO técnico (skill /perf-audit)
# ----------------------------------------------------------------------

# PageSpeed Insights API — opcional, melhora rate limit
# https://developers.google.com/speed/docs/insights/v5/get-started
PAGESPEED_API_KEY=

# ----------------------------------------------------------------------
# Pilar Dados — DataForSEO (skills /keywords-volume, /competitor-pages,
# /competitor-keywords)
# ----------------------------------------------------------------------
# Signup: https://app.dataforseo.com/register (Pay-as-you-go)
# Custos aproximados:
#   - /keywords-volume: ~$0.05 por keyword
#   - /competitor-pages: ~$0.30 por domínio
#   - /competitor-keywords: ~$0.30 por domínio
# Skills mostram preview de custo antes de chamar.
# Credenciais: Dashboard → API Access → API Login + API Password
# (são DIFERENTES do email/senha de login no site).
DATAFORSEO_LOGIN=
DATAFORSEO_PASSWORD=

# Locale default para queries DataForSEO (pode ser sobrescrito por --country flag)
# Códigos: https://docs.dataforseo.com/v3/serp/google/locations/
DATAFORSEO_LOCATION_CODE=2076
DATAFORSEO_LANGUAGE_CODE=pt
