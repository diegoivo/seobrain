{
  "name": "agentic-seo-kit",
  "version": "0.1.0",
  "description": "Agentic SEO Kit — orquestrador SEO/GEO multi-harness com Claude Code prioritário",
  "private": true,
  "type": "module",
  "scripts": {
    "setup": "npm run skills:install",
    "skills:install": "npx -y skills@latest add vercel-labs/agent-skills -y",
    "skills:update": "npx -y skills@latest update",
    "skills:list": "npx -y skills@latest list",
    "seo:score": "node scripts/seo-score.mjs",
    "brain:lint": "node scripts/brain-lint.mjs",
    "brain:lint:strict": "node scripts/brain-lint.mjs --strict",
    "content:sync": "node scripts/content-sync.mjs",
    "kit:reset-template": "node scripts/kit-reset-template.mjs",
    "web:dev": "cd web && npm run dev",
    "web:build": "cd web && npm run build"
  },
  "license": "MIT"
}
